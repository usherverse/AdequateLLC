# ADEQUATE CAPITAL LMS — PRODUCTION ENVIRONMENT TEMPLATE
# Copy this to .env and fill in your real credentials.

# ── SUPABASE CONFIG ──────────────────────────────────────────
# Find these in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role Key (Used for Edge Functions — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── M-PESA DARAJA API CONFIG ──────────────────────────────────
# Environment: 'sandbox' or 'production'
MPESA_ENVIRONMENT=sandbox

# Daraja Developer Portal -> My Apps
# Used for STK Push and B2C auth
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret

# C2B / STK Push Shortcode (Paybill/Till)
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# B2C Disbursement Shortcode
MPESA_B2C_SHORTCODE=600000
MPESA_B2C_INITIATOR_NAME=test-initiator
# This is the encrypted B2C security credential from the portal
MPESA_B2C_SECURITY_CREDENTIAL=your-encrypted-credential

# Callbacks (Must be public URLs, e.g. Supabase Edge Function URLs)
# Format: https://your-project-ref.functions.supabase.co/function-name
MPESA_CALLBACK_URL=https://your-project-ref.functions.supabase.co/mpesa-c2b-callback
MPESA_B2C_CALLBACK_URL=https://your-project-ref.functions.supabase.co/mpesa-b2c-callback
