# ADEQUATE CAPITAL LMS — PRODUCTION ENVIRONMENT TEMPLATE
# Copy this to .env and fill in your real credentials.

# ── SUPABASE CONFIG ──────────────────────────────────────────
# Find these in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role Key (Used for Edge Functions — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── M-PESA DARAJA API CONFIG ──────────────────────────────────
# Environment: 'sandbox' or 'production'
MPESA_ENVIRONMENT=sandbox

# Daraja Developer Portal -> My Apps
# Used for STK Push and B2C auth
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# C2B / STK Push Shortcode (Paybill/Till)
MPESA_SHORTCODE=
MPESA_PASSKEY=

# B2C Disbursement Config
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# Callback & Webhook URLs (must be publicly reachable)
MPESA_B2C_RESULT_URL=
MPESA_B2C_TIMEOUT_URL=
MPESA_C2B_CONFIRMATION_URL=
MPESA_C2B_VALIDATION_URL=
MPESA_STK_CALLBACK_URL=

# Cryptography (32-byte hex string for AES-256-GCM)
MPESA_ENCRYPTION_KEY=

